# --- SUPABASE (БАЗА ДАННЫХ) ---
# Получить в: Supabase Project -> Settings -> API
VITE_SUPABASE_URL=             # Ссылка (Project URL)
VITE_SUPABASE_ANON_KEY=        # Публичный anon key
SUPABASE_SERVICE_ROLE_KEY=     # Приватный service_role key (ВАЖНО для бэкенда)

# --- TELEGRAM BOT ---
# Получить у @BotFather
TELEGRAM_BOT_TOKEN=            # Токен вашего бота
VITE_TELEGRAM_BOT_NAME=        # Юзернейм бота без @ (например, izinet_vpn_bot)
TELEGRAM_ADMIN_ID=             # Ваш ID в Telegram (через @userinfobot) для уведомлений

# --- ПЛАТЕЖИ (ENOT.IO) ---
# Получить в Личном кабинете Enot.io -> Настройки кассы
ENOT_MERCHANT_ID=              # ID кассы (UUID)
ENOT_SECRET_KEY=               # Секретный пароль №1
ENOT_SECRET_KEY2=              # Секретный пароль №2 (для Webhook уведомлений)

# --- ПЛАТЕЖИ (CRYPTOMUS - Опционально) ---
CRYPTOMUS_MERCHANT_ID=
CRYPTOMUS_API_KEY=

# --- ОСНОВНОЙ VPN СЕРВЕР (3X-UI) ---
# Настройки для подключения к панели по умолчанию
XUI_HOST=                      # URL панели (например, http://1.2.3.4:2053/secret_path/)
XUI_USERNAME=                  # Логин в панель
XUI_PASSWORD=                  # Пароль в панель
XUI_INBOUND_ID=1               # ID входящего подключения (обычно 1)

# --- ПРОЧЕЕ ---
VITE_API_URL=                  # URL вашего бекенда. ПРИМЕР: http://000.00.00.00:3005
                               # Если ваш сайт доступен по адресу http://мой-ip:3005, то укажите его тут.
                               # Оставьте пустым, если Docker запускается на том же IP, что и браузер.
NODE_ENV=production            # Режим работы
